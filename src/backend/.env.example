PORT=3000
NODE_ENV=production

# Required: AES key used to encrypt/decrypt passwords (must match front-end)
ENCRYPTION_KEY=your-secret-encryption-key-here

# Optional: Bearer token clients must include (leave blank to disable)
API_KEY=

# Optional: comma-separated IPs to block
BAN_LIST=

# Default Synergy district URL
DEFAULT_DISTRICT_URL=https://md-mcps-psv.edupoint.com

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Cache TTLs (ms)
VIEWSTATE_TTL=21600000
TASK_QUEUE_TTL=1800000

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=
